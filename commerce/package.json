{
  "name": "magnet-commerce",
  "version": "1.0.0",
  "description": "Magnet Manufacturing Platform - Medusa.js Commerce Backend",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
