    "seed": "ts-node src/seed.ts",
    "migrate": "ts-node src/migrations/run.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@medusajs/medusa": "^1.20.0",
    "@medusajs/cache-inmemory": "^1.8.0",
    "@medusajs/event-bus-local": "^1.9.0",
    "@medusajs/medusa-cli": "^1.3.0",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "typeorm": "^0.3.17",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0"
